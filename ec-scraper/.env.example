# ===========================================
# EC Scraper Discovery API Configuration
# ===========================================

# API Authentication (required for production)
DISCOVERY_API_TOKEN=your-secret-api-token-here

# Supabase Configuration (required for Supabase writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Legacy PostgreSQL Database (optional, for backward compatibility)
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ===========================================
# AI Provider Keys (required)
# ===========================================

# Vertex AI Configuration (Recommended for production - uses IAM auth)
# Set to "true" to use Vertex AI Gemini API with IAM authentication
# Set to "false" to use Gemini Developer API with API keys
USE_VERTEX_AI=true

# Vertex AI Project Configuration (required when USE_VERTEX_AI=true)
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1

# Gemini API Key (only used when USE_VERTEX_AI=false)
GOOGLE_API_KEY=your_gemini_api_key_here

# ===========================================
# Model Configuration (optional)
# ===========================================

GEMINI_PRO_MODEL=gemini-3-flash-preview
GEMINI_FLASH_MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=text-embedding-004

# ===========================================
# Search Configuration (optional)
# ===========================================

# SearXNG instance URL (for web search)
SEARXNG_URL=http://localhost:8080

# ===========================================
# Local Development Paths (optional)
# ===========================================

SQLITE_DB_PATH=./data/ec_database.db
CHROMA_DB_PATH=./data/chroma

# ===========================================
# Scraping Configuration (optional)
# ===========================================

MAX_CONCURRENT_SCRAPES=5
SCRAPE_TIMEOUT_SECONDS=30

# ===========================================
# Server Configuration (Railway sets PORT)
# ===========================================

PORT=8000
